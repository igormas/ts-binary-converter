{
  "name": "ts-binary-converter",
  "version": "1.0.0",
  "description": "A TypeScript library to convert values to binary and back",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "binary",
    "converter",
    "typescript",
    "binary-conversion",
    "encode",
    "decode"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.12",
    "@typescript-eslint/eslint-plugin": "^7.9.0",
    "@typescript-eslint/parser": "^7.9.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.3",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts"
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/igormas/ts-binary-converter.git"
  },
  "bugs": {
    "url": "https://github.com/igormas/ts-binary-converter/issues"
  },
  "homepage": "https://github.com/igormas/ts-binary-converter#readme"
}
